// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Potato {
  id            String    @id @default(cuid())
  message       String    @db.Text
  author        String    // nickname
  passwordHash  String?   // for user-submitted potatoes
  likes         Int       @default(0)
  commentsCount Int       @default(0)
  isDefault     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  comments      Comment[]

  @@index([likes])
  @@index([createdAt])
}

model Comment {
  id           String   @id @default(cuid())
  potatoId     String
  author       String   // nickname
  passwordHash String   // for deleting/editing comments
  message      String   @db.Text
  createdAt    DateTime @default(now())
  potato       Potato   @relation(fields: [potatoId], references: [id], onDelete: Cascade)

  @@index([potatoId])
}
